{
  "name": "mapwar",
  "version": "1.0.0",
  "description": "MAPWAR — 历史大乱斗。在真实历史地理地图上，百余势力（历史上的政权、民族、大家族）各据一城，展开跨越时空的沙盘战争。",
  "main": "game.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"node auto_backup.cjs\"",
    "build": "vite build",
    "preview": "vite preview",
    "tier:export": "npx tsx scratch/assign_flag_template_by_tier.ts",
    "tier:check": "npx tsx scratch/check_tier_audit_conflicts.mjs",
    "flag-text:check": "npx tsx scratch/audit_flag_text_luminance.mjs",
    "expedition:audit": "npx tsx scratch/audit_expedition_regions.mjs",
    "expedition:triple-check": "npx tsx scratch/audit_expedition_triple_names.mjs",
    "expedition:coverage": "npx tsx scratch/audit_expedition_coverage.mjs",
    "skeleton:audit": "npx tsx scratch/audit_skeleton_anchors.mjs",
    "city:spacing": "npx tsx scratch/audit_city_spacing.mjs",
    "portrait:folder-audit": "node scratch/dedupe_portraits_within_folder.mjs --audit",
    "portrait:folder-dedupe": "node scratch/dedupe_portraits_within_folder.mjs",
    "portrait:culture-folders": "node scratch/audit_region_portrait_folders.mjs",
    "city:dossier": "npx tsx scratch/export_city_dossier.mjs",
    "city:lookup": "npx tsx scratch/export_city_dossier.mjs --",
    "add:check": "npx tsx scratch/audit_add_completeness.mjs --",
    "faction:sync-audit": "npx tsx scratch/audit_faction_capital_sync.mjs",
    "tier:pending": "node scratch/export_faction_tier_pending.mjs",
    "audit": "node scripts/audit-game-integrity.mjs",
    "sim": "tsx scripts/sim/headless.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "pinyin-pro": "^3.28.0"
  }
}
